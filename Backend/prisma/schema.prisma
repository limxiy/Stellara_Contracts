// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String   @id @default(cuid())
  walletAddress   String   @unique @map("wallet_address")
  profileData     Json?    @map("profile_data")
  reputationScore Int      @default(0) @map("reputation_score")
  trustScore      Int      @default(500) @map("trust_score")
  reputationLevel String   @default("BRONZE") @map("reputation_level")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  // Notification fields
  email            String? @unique
  pushSubscription Json?   @map("push_subscription")

  // Relations
  createdProjects      Project[]            @relation("ProjectCreator")
  contributions        Contribution[]
  reputationHistory    ReputationHistory[]
  notificationSettings NotificationSetting[]
  notifications        Notification[]
  insurancePolicies    InsurancePolicy[]

  @@map("users")
}

model Project {
  id           String        @id @default(cuid())
  contractId   String        @unique @map("contract_id")
  creatorId    String        @map("creator_id")
  creator      User          @relation("ProjectCreator", fields: [creatorId], references: [id])
  title        String
  description  String?
  category     String
  goal         BigInt
  currentFunds BigInt        @default(0) @map("current_funds")
  deadline     DateTime
  ipfsHash     String?       @map("ipfs_hash")
  status       ProjectStatus @default(ACTIVE)
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  // Relations
  contributions Contribution[]
  milestones    Milestone[]
  // publicGoodsProject PublicGoodsProject?  // TODO: Define PublicGoodsProject model

  @@map("projects")
}

model Contribution {
  id              String   @id @default(cuid())
  transactionHash String   @unique @map("transaction_hash")
  investorId      String   @map("investor_id")
  investor        User     @relation(fields: [investorId], references: [id])
  projectId       String   @map("project_id")
  project         Project  @relation(fields: [projectId], references: [id])
  amount          BigInt
  timestamp       DateTime @default(now())
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("contributions")
}

model Milestone {
  id             String          @id @default(cuid())
  projectId      String          @map("project_id")
  project        Project         @relation(fields: [projectId], references: [id])
  contractMilestoneId String?    @map("contract_milestone_id")
  title          String
  description    String?
  fundingAmount  BigInt          @map("funding_amount")
  status         MilestoneStatus @default(PENDING)
  completionDate DateTime?       @map("completion_date")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  @@unique([projectId, contractMilestoneId])
  @@index([projectId, contractMilestoneId])
  @@map("milestones")
}

model ReputationHistory {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  user        User     @relation(fields: [userId], references: [id])
  scoreChange Int      @map("score_change")
  reason      String
  timestamp   DateTime @default(now())
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("reputation_history")
}

model Category {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("categories")
}

enum ProjectStatus {
  ACTIVE
  COMPLETED
  CANCELLED
  SUSPENDED
}

enum MilestoneStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
  FUNDED
}

model LedgerCursor {
  id             String   @id @default(cuid())
  network        String   @unique
  lastLedgerSeq  Int      @map("last_ledger_seq")
  lastLedgerHash String?  @map("last_ledger_hash")
  updatedAt      DateTime @updatedAt @map("updated_at")
  createdAt      DateTime @default(now()) @map("created_at")

  @@map("ledger_cursors")
}

model ProcessedEvent {
  id              String   @id @default(cuid())
  eventId         String   @unique @map("event_id")
  network         String
  ledgerSeq       Int      @map("ledger_seq")
  contractId      String   @map("contract_id")
  eventType       String   @map("event_type")
  transactionHash String   @map("transaction_hash")
  processedAt     DateTime @default(now()) @map("processed_at")

  @@index([network, ledgerSeq])
  @@index([contractId, eventType])
  @@map("processed_events")
}

model IndexerLog {
  id        String   @id @default(cuid())
  level     String
  message   String
  metadata  Json?
  timestamp DateTime @default(now())
  createdAt DateTime @default(now()) @map("created_at")

  @@index([timestamp])
  @@index([level])
  @@map("indexer_logs")
}

model NotificationSetting {
  id                  String   @id @default(cuid())
  userId              String   @unique @map("user_id")
  user                User     @relation(fields: [userId], references: [id])
  emailEnabled        Boolean  @default(true) @map("email_enabled")
  pushEnabled         Boolean  @default(false) @map("push_enabled")
  notifyContributions Boolean  @default(true) @map("notify_contributions")
  notifyMilestones    Boolean  @default(true) @map("notify_milestones")
  notifyDeadlines     Boolean  @default(true) @map("notify_deadlines")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@map("notification_settings")
}

model Notification {
  id        String           @id @default(cuid())
  userId    String           @map("user_id")
  user      User             @relation(fields: [userId], references: [id])
  type      NotificationType
  title     String
  message   String
  read      Boolean          @default(false)
  data      Json? // Optional metadata (e.g., projectId)
  createdAt DateTime         @default(now()) @map("created_at")

  @@index([userId])
  @@map("notifications")
}

model EmailOutbox {
  id        String      @id @default(cuid())
  to        String
  subject   String
  html      String
  status    EmailStatus @default(PENDING)
  attempts  Int         @default(0)
  lastError String?     @map("last_error")
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")

  @@index([status])
  @@map("email_outbox")
}

model NotificationOutbox {
  id             String              @id @default(cuid())
  notificationId String?             @map("notification_id")
  userId         String              @map("user_id")
  channel        NotificationChannel
  status         DeliveryStatus      @default(PENDING)
  dedupKey       String              @unique @map("dedup_key")
  payload        Json
  attempts       Int                 @default(0)
  maxAttempts    Int                 @default(3) @map("max_attempts")
  nextRetryAt    DateTime            @default(now()) @map("next_retry_at")
  lastAttemptAt  DateTime?           @map("last_attempt_at")
  retryDisabled  Boolean             @default(false) @map("retry_disabled")
  lastError      String?             @map("last_error")
  createdAt      DateTime            @default(now()) @map("created_at")
  updatedAt      DateTime            @updatedAt @map("updated_at")

  @@index([status, nextRetryAt])
  @@index([userId, channel])
  @@map("notification_outbox")
}

enum NotificationType {
  CONTRIBUTION
  MILESTONE
  DEADLINE
  SYSTEM
}

enum EmailStatus {
  PENDING
  SENT
  FAILED
}

enum NotificationChannel {
  EMAIL
  PUSH
}

enum DeliveryStatus {
  PENDING
  SENT
  FAILED
}

// Insurance Module Models

enum RiskType {
  PROJECT_FAILURE
  SMART_CONTRACT_EXPLOIT
  MARKET_VOLATILITY
  PARAMETRIC_WEATHER
}

enum PoolRiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum PoolAlertSeverity {
  INFO
  WARNING
  CRITICAL
  EMERGENCY
}

enum PoolAlertType {
  LOW_LIQUIDITY
  HIGH_UTILIZATION
  EXPOSURE_LIMIT_REACHED
  HEALTH_SCORE_DROP
  REBALANCE_REQUIRED
  LARGE_CLAIM
}

enum PolicyStatus {
  ACTIVE
  EXPIRED
  CANCELLED
  CLAIMED
}

enum ClaimStatus {
  PENDING
  REVIEWING
  APPROVED
  REJECTED
  PAID
  DISPUTED
}

enum AssessmentStage {
  INITIAL_REVIEW
  DOCUMENT_VERIFICATION
  RISK_ASSESSMENT
  FINAL_APPROVAL
}

enum AssessorRole {
  JUNIOR_ASSESSOR
  SENIOR_ASSESSOR
  CLAIMS_MANAGER
  DISPUTE_RESOLVER
}

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED
  ESCALATED
}

model InsurancePolicy {
  id             String    @id @default(cuid())
  userId         String    @map("user_id")
  user           User      @relation(fields: [userId], references: [id])
  poolId         String    @map("pool_id")
  pool           InsurancePool @relation(fields: [poolId], references: [id])
  riskType       RiskType  @map("risk_type")
  premium        Decimal   @map("premium")
  coverageAmount Decimal   @map("coverage_amount")
  status         PolicyStatus @default(ACTIVE)
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  claims         Claim[]

  @@map("insurance_policies")
}

model InsurancePool {
  id            String   @id @default(cuid())
  name          String
  description   String?  @map("description")
  capital       Decimal  @default(0)
  lockedCapital Decimal  @default(0) @map("locked_capital")
  totalPayouts  Decimal  @default(0) @map("total_payouts")
  totalPremiums Decimal  @default(0) @map("total_premiums")
  
  // Risk management fields
  maxExposureLimit    Decimal?  @map("max_exposure_limit")
  currentExposure     Decimal   @default(0) @map("current_exposure")
  riskLevel           PoolRiskLevel @default(LOW) @map("risk_level")
  utilizationThreshold Decimal  @default(0.75) @map("utilization_threshold")
  
  // Health monitoring
  healthScore         Int       @default(100) @map("health_score")
  isActive            Boolean   @default(true) @map("is_active")
  isRebalancing       Boolean   @default(false) @map("is_rebalancing")
  lastRebalanceAt     DateTime? @map("last_rebalance_at")
  lastHealthCheckAt   DateTime? @map("last_health_check_at")
  
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  insurancePolicies    InsurancePolicy[]
  reinsuranceContracts ReinsuranceContract[]
  claims               Claim[]
  poolAlerts           PoolAlert[]
  rebalanceHistory     PoolRebalanceHistory[]

  @@map("insurance_pools")
}

model Claim {
  id           String      @id @default(cuid())
  policyId     String      @map("policy_id")
  policy       InsurancePolicy @relation(fields: [policyId], references: [id])
  poolId       String?     @map("pool_id")
  pool         InsurancePool? @relation(fields: [poolId], references: [id])
  claimAmount  Decimal     @map("claim_amount")
  status       ClaimStatus @default(PENDING)
  payoutAmount Decimal?    @map("payout_amount")
  
  // Workflow fields
  currentStage AssessmentStage? @map("current_stage")
  isParametric Boolean     @default(false) @map("is_parametric")
  parametricTriggerData Json? @map("parametric_trigger_data")
  assessorId   String?     @map("assessor_id")
  assessor     Assessor?   @relation(fields: [assessorId], references: [id])
  
  // Timestamps
  submittedAt  DateTime    @default(now()) @map("submitted_at")
  reviewedAt   DateTime?   @map("reviewed_at")
  resolvedAt   DateTime?   @map("resolved_at")
  paidAt       DateTime?   @map("paid_at")
  
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  // Relations
  evidence     ClaimEvidence[]
  assessments  ClaimAssessment[]
  disputes     ClaimDispute[]

  @@map("claims")
}

model Assessor {
  id              String       @id @default(cuid())
  userId          String       @map("user_id")
  role            AssessorRole
  specialization  String?      @map("specialization")
  isActive        Boolean      @default(true) @map("is_active")
  workload        Int          @default(0)
  maxConcurrentClaims Int      @default(10) @map("max_concurrent_claims")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  // Relations
  assignedClaims  Claim[]
  assessments     ClaimAssessment[]

  @@map("assessors")
}

model ClaimEvidence {
  id          String   @id @default(cuid())
  claimId     String   @map("claim_id")
  claim       Claim    @relation(fields: [claimId], references: [id])
  ipfsHash    String   @map("ipfs_hash")
  documentType String  @map("document_type")
  description String?
  uploadedBy  String   @map("uploaded_by")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("claim_evidence")
}

model ClaimAssessment {
  id              String           @id @default(cuid())
  claimId         String           @map("claim_id")
  claim           Claim            @relation(fields: [claimId], references: [id])
  assessorId      String           @map("assessor_id")
  assessor        Assessor         @relation(fields: [assessorId], references: [id])
  stage           AssessmentStage
  decision        ClaimStatus?
  score           Int?             @map("assessment_score")
  notes           String?
  parametricScore Decimal?         @map("parametric_score")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  @@map("claim_assessments")
}

model ClaimDispute {
  id          String        @id @default(cuid())
  claimId     String        @map("claim_id")
  claim       Claim         @relation(fields: [claimId], references: [id])
  raisedBy    String        @map("raised_by")
  reason      String
  status      DisputeStatus @default(OPEN)
  resolution  String?
  resolvedBy  String?       @map("resolved_by")
  resolvedAt  DateTime?     @map("resolved_at")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  @@map("claim_disputes")
}

// Reinsurance Enums
enum ReinsuranceType {
  QUOTA_SHARE
  SURPLUS
  EXCESS_OF_LOSS
  STOP_LOSS
  FACULTATIVE
  TREATY
}

enum ReinsuranceStatus {
  ACTIVE
  EXPIRED
  CANCELLED
  SUSPENDED
}

enum ReinsuranceClaimStatus {
  PENDING
  SUBMITTED_TO_REINSURER
  UNDER_REVIEW
  APPROVED
  REJECTED
  SETTLED
  DISPUTED
}

model ReinsuranceContract {
  id             String           @id @default(cuid())
  poolId         String           @map("pool_id")
  pool           InsurancePool    @relation(fields: [poolId], references: [id])
  
  // Contract details
  reinsurerName  String           @map("reinsurer_name")
  reinsurerContact Json?          @map("reinsurer_contact")
  type           ReinsuranceType  @default(QUOTA_SHARE)
  coverageLimit  Decimal          @map("coverage_limit")
  premiumRate    Decimal          @map("premium_rate")
  deductible     Decimal          @default(0)
  attachmentPoint Decimal?       @map("attachment_point")
  exhaustionPoint Decimal?       @map("exhaustion_point")
  
  // Coverage terms
  startDate      DateTime         @map("start_date")
  endDate        DateTime         @map("end_date")
  status         ReinsuranceStatus @default(ACTIVE)
  
  // Financial tracking
  totalPremiumsPaid Decimal      @default(0) @map("total_premiums_paid")
  totalClaimsReceived Decimal    @default(0) @map("total_claims_received")
  totalClaimsPaid Decimal        @default(0) @map("total_claims_paid")
  availableCoverage Decimal      @map("available_coverage")
  
  // Terms and conditions
  terms          String?
  notes          String?
  metadata       Json?
  
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")

  claims         ReinsuranceClaim[]

  @@index([poolId, status])
  @@index([startDate, endDate])
  @@map("reinsurance_contracts")
}

model ReinsuranceClaim {
  id              String                @id @default(cuid())
  contractId      String                @map("contract_id")
  contract        ReinsuranceContract   @relation(fields: [contractId], references: [id])
  originalClaimId String?               @map("original_claim_id")
  originalClaim   Claim?                @relation(fields: [originalClaimId], references: [id])
  
  // Claim details
  claimAmount     Decimal               @map("claim_amount")
  requestedAmount Decimal               @map("requested_amount")
  approvedAmount  Decimal?              @map("approved_amount")
  paidAmount      Decimal?              @map("paid_amount")
  
  // Status tracking
  status          ReinsuranceClaimStatus @default(PENDING)
  rejectionReason String?               @map("rejection_reason")
  
  // Workflow tracking
  submittedToReinsurerAt DateTime?      @map("submitted_to_reinsurer_at")
  reinsurerResponseAt  DateTime?        @map("reinsurer_response_at")
  settledAt           DateTime?         @map("settled_at")
  
  // Documentation
  supportingDocuments Json?             @map("supporting_documents")
  reinsurerNotes      String?           @map("reinsurer_notes")
  
  createdAt         DateTime            @default(now()) @map("created_at")
  updatedAt         DateTime            @updatedAt @map("updated_at")

  @@index([contractId, status])
  @@index([originalClaimId])
  @@map("reinsurance_claims")
}

model PoolAlert {
  id          String           @id @default(cuid())
  poolId      String           @map("pool_id")
  pool        InsurancePool    @relation(fields: [poolId], references: [id])
  alertType   PoolAlertType    @map("alert_type")
  severity    PoolAlertSeverity
  message     String
  metadata    Json?
  isResolved  Boolean          @default(false) @map("is_resolved")
  resolvedAt  DateTime?        @map("resolved_at")
  createdAt   DateTime         @default(now()) @map("created_at")

  @@index([poolId, isResolved])
  @@index([severity, createdAt])
  @@map("pool_alerts")
}

model PoolRebalanceHistory {
  id              String   @id @default(cuid())
  poolId          String   @map("pool_id")
  pool            InsurancePool @relation(fields: [poolId], references: [id])
  reason          String
  actionsTaken    Json     @map("actions_taken")
  previousState   Json     @map("previous_state")
  newState        Json     @map("new_state")
  executedBy      String?  @map("executed_by")
  executedAt      DateTime @default(now()) @map("executed_at")

  @@index([poolId, executedAt])
  @@map("pool_rebalance_history")
}
