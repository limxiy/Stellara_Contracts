// Reputation Snapshot Models

model ReputationSnapshot {
  id                  String   @id @default(cuid())
  period              SnapshotPeriod @map("period")
  periodStart         DateTime @map("period_start")
  periodEnd           DateTime @map("period_end")
  totalUsers          Int      @map("total_users")
  activeUsers         Int      @map("active_users")
  averageScore        Float    @map("average_score")
  medianScore         Float    @map("median_score")
  highestScore        Int      @map("highest_score")
  lowestScore         Int      @map("lowest_score")
  scoreDistribution   Json     @map("score_distribution") // Distribution by score ranges
  levelDistribution   Json     @map("level_distribution") // Distribution by reputation levels
  totalActivities     Int      @map("total_activities")
  newUsers            Int      @map("new_users")
  decayedUsers        Int      @map("decayed_users")
  decayedAmount       Float    @map("decayed_amount")
  metadata            Json?    @map("metadata")
  createdAt           DateTime @default(now()) @map("created_at")

  // Relations
  userSnapshots        ReputationUserSnapshot[]
  comparisonsAsFirst   SnapshotComparison[] @relation("ComparisonSnapshot1")
  comparisonsAsSecond  SnapshotComparison[] @relation("ComparisonSnapshot2")

  @@unique([period, periodStart])
  @@index([period])
  @@index([periodStart])
  @@map("reputation_snapshots")
}

model ReputationUserSnapshot {
  id                  String   @id @default(cuid())
  snapshotId          String   @map("snapshot_id")
  snapshot            ReputationSnapshot @relation(fields: [snapshotId], references: [id])
  userId              String   @map("user_id")
  user                User     @relation(fields: [userId], references: [id])
  reputationScore     Int      @map("reputation_score")
  trustScore          Int      @map("trust_score")
  reputationLevel     String   @map("reputation_level")
  activityCount       Int      @map("activity_count")
  successRate         Float    @map("success_rate")
  reliabilityScore    Float    @map("reliability_score")
  communityScore      Float    @map("community_score")
  expertiseScore      Float    @map("expertise_score")
  contributionSize    Float    @map("contribution_size")
  peerRatingScore     Float    @map("peer_rating_score")
  communityFeedbackScore Float @map("community_feedback_score")
  compositeScore      Float    @map("composite_score")
  rank                Int?     @map("rank") // Global ranking at snapshot time
  percentile          Float?   @map("percentile") // Percentile at snapshot time
  changeFromPrevious  Json?    @map("change_from_previous") // Changes from previous snapshot
  metadata            Json?    @map("metadata")
  createdAt           DateTime @default(now()) @map("created_at")

  @@unique([snapshotId, userId])
  @@index([snapshotId])
  @@index([userId])
  @@index([reputationScore])
  @@map("reputation_user_snapshots")
}

model ReputationTrend {
  id                  String   @id @default(cuid())
  userId              String   @map("user_id")
  user                User     @relation(fields: [userId], references: [id])
  trendType           TrendType @map("trend_type")
  period              TrendPeriod @map("period")
  startDate           DateTime @map("start_date")
  endDate             DateTime @map("end_date")
  startScore          Int      @map("start_score")
  endScore            Int      @map("end_score")
  scoreChange         Int      @map("score_change")
  percentChange       Float    @map("percent_change")
  averageDailyChange  Float    @map("average_daily_change")
  volatility          Float    @map("volatility") // Standard deviation of daily changes
  trendDirection      TrendDirection @map("trend_direction")
  momentum            Float    @map("momentum") // Rate of change acceleration
  predictionScore     Int?     @map("prediction_score") // Predicted score for next period
  confidence          Float    @map("confidence") // Confidence in prediction (0-1)
  factors             Json?    @map("factors") // Contributing factors to trend
  metadata            Json?    @map("metadata")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@unique([userId, trendType, period, startDate])
  @@index([userId, trendType])
  @@index([period])
  @@index([trendDirection])
  @@map("reputation_trends")
}

model SnapshotComparison {
  id                  String   @id @default(cuid())
  snapshotId1         String   @map("snapshot_id_1")
  snapshot1           ReputationSnapshot @relation("ComparisonSnapshot1", fields: [snapshotId1], references: [id])
  snapshotId2         String   @map("snapshot_id_2")
  snapshot2           ReputationSnapshot @relation("ComparisonSnapshot2", fields: [snapshotId2], references: [id])
  comparisonType      ComparisonType @map("comparison_type")
  metrics             Json     @map("metrics") // Detailed comparison metrics
  insights            Json?    @map("insights") // AI-generated insights
  significantChanges  Json     @map("significant_changes") // Notable changes
  recommendations     Json?    @map("recommendations") // Actionable recommendations
  similarityScore     Float    @map("similarity_score") // Overall similarity (0-1)
  createdAt           DateTime @default(now()) @map("created_at")

  @@unique([snapshotId1, snapshotId2, comparisonType])
  @@index([snapshotId1])
  @@index([snapshotId2])
  @@map("snapshot_comparisons")
}

enum SnapshotPeriod {
  DAILY
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
}

enum TrendType {
  SCORE_TREND
  ACTIVITY_TREND
  RANK_TREND
  LEVEL_TREND
  DECAY_TREND
  GROWTH_TREND
}

enum TrendPeriod {
  DAILY
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
}

enum TrendDirection {
  STRONGLY_DECLINING
  DECLINING
  STABLE
  INCREASING
  STRONGLY_INCREASING
}

enum ComparisonType {
  PERIOD_OVER_PERIOD
  YEAR_OVER_YEAR
  MONTH_OVER_MONTH
  WEEK_OVER_WEEK
  CUSTOM
}

// Reputation Dispute Models

model ReputationDispute {
  id                String               @id @default(cuid())
  userId            String               @map("user_id")
  user              User                 @relation(fields: [userId], references: [id])
  disputedActivityId String?             @map("disputed_activity_id")
  disputedActivity  ReputationActivity?  @relation(fields: [disputedActivityId], references: [id])
  disputeType       DisputeType          @map("dispute_type")
  reason            String
  description       String
  evidence          Json?                @map("evidence")
  previousScore     Int                  @map("previous_score")
  requestedScore    Int?                 @map("requested_score")
  status            DisputeStatus        @default(PENDING)
  priority          DisputePriority      @default(MEDIUM)
  moderatorId       String?              @map("moderator_id")
  moderator         User?                @relation("DisputeModerator", fields: [moderatorId], references: [id])
  moderatorNotes    String?              @map("moderator_notes")
  resolution        DisputeResolution?
  resolutionId      String?              @unique @map("resolution_id")
  automatedResolution Boolean            @default(false) @map("automated_resolution")
  submittedAt       DateTime             @default(now()) @map("submitted_at")
  reviewedAt        DateTime?            @map("reviewed_at")
  resolvedAt        DateTime?            @map("resolved_at")
  createdAt         DateTime             @default(now()) @map("created_at")
  updatedAt         DateTime             @updatedAt @map("updated_at")

  // Relations
  disputeComments DisputeComment[]

  @@index([userId, status])
  @@index([status, priority])
  @@index([moderatorId])
  @@index([submittedAt])
  @@map("reputation_disputes")
}

model DisputeResolution {
  id                  String               @id @default(cuid())
  disputeId           String               @unique @map("dispute_id")
  dispute             ReputationDispute    @relation(fields: [disputeId], references: [id])
  finalScore          Int?                 @map("final_score")
  scoreAdjustment     Int                  @map("score_adjustment")
  resolutionType      ResolutionType       @map("resolution_type")
  explanation         String
  evidence            Json?                @map("evidence")
  moderatorId         String?              @map("moderator_id")
  moderator           User?                @relation("ResolutionModerator", fields: [moderatorId], references: [id])
  approvedBy          String?              @map("approved_by")
  approvalNotes       String?              @map("approval_notes")
  isFinal             Boolean              @default(true) @map("is_final")
  canAppeal           Boolean              @default(true) @map("can_appeal")
  appealDeadline      DateTime?            @map("appeal_deadline")
  resolvedAt          DateTime             @default(now()) @map("resolved_at")
  createdAt           DateTime             @default(now()) @map("created_at")

  @@map("dispute_resolutions")
}

model DisputeComment {
  id         String            @id @default(cuid())
  disputeId  String            @map("dispute_id")
  dispute    ReputationDispute @relation(fields: [disputeId], references: [id])
  authorId   String            @map("author_id")
  author     User              @relation(fields: [authorId], references: [id])
  content    String
  isInternal Boolean           @default(false) @map("is_internal")
  createdAt  DateTime          @default(now()) @map("created_at")
  updatedAt  DateTime          @updatedAt @map("updated_at")

  @@index([disputeId, createdAt])
  @@index([authorId])
  @@map("dispute_comments")
}

model DisputeMetrics {
  id                    String   @id @default(cuid())
  totalDisputes         Int      @default(0) @map("total_disputes")
  pendingDisputes       Int      @default(0) @map("pending_disputes")
  resolvedDisputes      Int      @default(0) @map("resolved_disputes")
  automatedResolutions  Int      @default(0) @map("automated_resolutions")
  averageResolutionTime Float    @default(0) @map("average_resolution_time")
  successRate           Float    @default(0) @map("success_rate")
  appealRate            Float    @default(0) @map("appeal_rate")
  period                String   @map("period") // 'daily', 'weekly', 'monthly'
  periodStart           DateTime @map("period_start")
  periodEnd             DateTime @map("period_end")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  @@unique([period, periodStart])
  @@map("dispute_metrics")
}

enum DisputeType {
  SCORE_CALCULATION_ERROR
  UNFAIR_ACTIVITY_RECORDING
  MISSING_ACTIVITY
  DUPLICATE_ACTIVITY
  DECAY_DISAGREEMENT
  TECHNICAL_GLITCH
  OTHER
}

enum DisputeStatus {
  PENDING
  UNDER_REVIEW
  AWAITING_EVIDENCE
  RESOLVED
  REJECTED
  APPEALED
  CLOSED
}

enum DisputePriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ResolutionType {
  SCORE_ADJUSTMENT
  ACTIVITY_CORRECTION
  DECAY_REVERSAL
  FULL_REVERSAL
  MANUAL_OVERRIDE
  AUTOMATED_CORRECTION
  REJECTED
}

// Dead Letter Queue (#682)
enum DlqStatus {
  PENDING
  FAILED
  RESOLVED
}

model DeadLetterQueue {
  id         String    @id @default(cuid())
  eventType  String    @map("event_type")
  payload    Json
  source     String
  lastError  String    @map("last_error")
  attempts   Int       @default(0)
  status     DlqStatus @default(PENDING)
  resolvedAt DateTime? @map("resolved_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  @@index([status])
  @@index([eventType])
  @@index([createdAt])
  @@map("dead_letter_queue")
}

// Idempotency Keys (#683)
model IdempotencyKey {
  id         String   @id @default(cuid())
  key        String   @unique
  statusCode Int      @map("status_code")
  response   Json
  expiresAt  DateTime @map("expires_at")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([expiresAt])
  @@map("idempotency_keys")
}

model FeatureFlag {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  isEnabled   Boolean  @default(false) @map("is_enabled")
  rules       Json?    // Targeting rules (e.g., user groups, percent of users)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("feature_flags")
}

// ─── Auth: RBAC, JWT Refresh, Session (#705, #707, #708) ───────────────────

model Role {
  id          String       @id @default(cuid())
  name        String       @unique
  permissions Permission[]
  users       UserRole[]
  createdAt   DateTime     @default(now()) @map("created_at")

  @@map("roles")
}

model Permission {
  id     String @id @default(cuid())
  action String @unique // e.g. "user:read", "admin:write"
  roles  Role[]

  @@map("permissions")
}

model UserRole {
  userId    String   @map("user_id")
  roleId    String   @map("role_id")
  role      Role     @relation(fields: [roleId], references: [id])
  assignedAt DateTime @default(now()) @map("assigned_at")

  @@id([userId, roleId])
  @@map("user_roles")
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@map("refresh_tokens")
}

model Session {
  id         String    @id @default(cuid())
  userId     String    @map("user_id")
  token      String    @unique
  ipAddress  String?   @map("ip_address")
  userAgent  String?   @map("user_agent")
  lastSeenAt DateTime  @default(now()) @map("last_seen_at")
  expiresAt  DateTime  @map("expires_at")
  terminatedAt DateTime? @map("terminated_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  @@index([userId])
  @@map("sessions")
}

// ─── Security Audit Logging ─────────────────────────────────────────────────

model AuditLog {
  id          String   @id @default(cuid())
  eventType   String   @map("event_type")
  severity    String
  userId      String?  @map("user_id")
  targetId    String?  @map("target_id")
  description String?
  ipAddress   String?  @map("ip_address")
  userAgent   String?  @map("user_agent")
  metadata    Json?    // Additional structured data
  createdAt   DateTime @default(now()) @map("created_at")

  // Indexes for common query patterns
  @@index([eventType])
  @@index([severity])
  @@index([userId])
  @@index([targetId])
  @@index([createdAt])
  @@index([eventType, createdAt])
  @@index([severity, createdAt])
  @@index([userId, createdAt])
  @@map("audit_logs")
}
