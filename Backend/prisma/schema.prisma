  // Claim details
  claimAmount     Decimal               @map("claim_amount")
  requestedAmount Decimal               @map("requested_amount")
  approvedAmount  Decimal?              @map("approved_amount")
  paidAmount      Decimal?              @map("paid_amount")
  
  // Status tracking
  status          ReinsuranceClaimStatus @default(PENDING)
  rejectionReason String?               @map("rejection_reason")
  
  // Workflow tracking
  submittedToReinsurerAt DateTime?      @map("submitted_to_reinsurer_at")
  reinsurerResponseAt  DateTime?        @map("reinsurer_response_at")
  settledAt           DateTime?         @map("settled_at")
  
  // Documentation
  supportingDocuments Json?             @map("supporting_documents")
  reinsurerNotes      String?           @map("reinsurer_notes")
  
  createdAt         DateTime            @default(now()) @map("created_at")
  updatedAt         DateTime            @updatedAt @map("updated_at")

  @@index([contractId, status])
  @@index([originalClaimId])
  @@map("reinsurance_claims")
}

